# ElevenLabs WebUI Client Configuration
# Copy this file to .env and fill in your values

# Firebase refresh tokens (comma-separated)
# ELEVENLABS_FIREBASE_REFRESH_TOKENS=

# Single legacy refresh token
# ELEVENLABS_FIREBASE_REFRESH_TOKEN=

# Browser profile path for auto-extraction
# ELEVENLABS_WEBUI_PROFILE_DIR=

# Profile auth cache TTL in seconds (default: 900)
# ELEVENLABS_WEBUI_PROFILE_REFRESH_SECONDS=900

# Auth mode: auto, webui, bearer, firebase, or api (default: auto)
# ELEVENLABS_AUTH_MODE=auto

# Set to 1 to force WebUI auth only, disabling API key fallback
# ELEVENLABS_DISABLE_API_KEY_FALLBACK=0

# Classic API key fallback
# ELEVENLABS_API_KEYS=
# ELEVENLABS_API_KEY=

# Default TTS model (default: eleven_v3)
# ELEVENLABS_MODEL_ID=eleven_v3

# Spanish override when default is eleven_v3
# ELEVENLABS_MODEL_ID_ES=eleven_multilingual_v2

# Set to 1 for debug output
# ELEVENLABS_DEBUG=